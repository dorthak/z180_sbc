CROSS_AS=~/vasm/vasmz80_oldstyle
CROSS_AS_FLAGS=-Fbin -esc -dotdir -hd64180 -ldots -I./lib -I./cpm

# Location of the flash program for flashing ROM using Retro Ptrogrammer

FLASH_PROG=~/z80-retro/2065-Z80-programmer/pi/flash

# For flashing SD card on a plain Raspberry PI - device for the SD card
SD_DEV=/dev/sda1

# This is used before burning an SD card image to make sure we are on the correct host!
SD_HOSTNAME=Retro

DISKDEF=z80-retro-2k-8m

